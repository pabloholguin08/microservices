# Copy this file to .env for local docker compose runs.
# These are local-only demo credentials, not meant for any real deployment.

# orders-service database
ORDERS_DB_NAME=orders_db
ORDERS_DB_USER=orders_user
ORDERS_DB_PASSWORD=orders_pass

# inventory-service database
INVENTORY_DB_NAME=inventory_db
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_pass

# notification-service database
NOTIFICATIONS_DB_NAME=notifications_db
NOTIFICATIONS_DB_USER=notifications_user
NOTIFICATIONS_DB_PASSWORD=notifications_pass

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

{
  "title": "Pedidos — Overview",
  "uid": "pedidos-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    { "type": "row", "title": "HTTP", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "id": 100 },

    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate",
      "description": "HTTP requests/sec per service",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "description": "HTTP 5xx responses/sec per service",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p95",
      "description": "95th percentile HTTP request duration per service",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le, job))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },

    { "type": "row", "title": "Order saga", "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }, "id": 101 },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Orders placed / confirmed / cancelled",
      "description": "Business-level saga outcomes (Micrometer counters, not derived from HTTP status)",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(orders_placed_total[1m]))",
          "legendFormat": "placed",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(orders_confirmed_total[1m]))",
          "legendFormat": "confirmed",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(orders_cancelled_total[1m])) by (reason)",
          "legendFormat": "cancelled ({{reason}})",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Stock rejections",
      "description": "inventory-service rejecting an order, by reason",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(stock_rejections_total[1m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },

    { "type": "row", "title": "Messaging", "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }, "id": 102 },

    {
      "id": 6,
      "type": "timeseries",
      "title": "RabbitMQ queue depth",
      "description": "Ready (unconsumed) messages per queue — a growing line means a consumer is falling behind or down",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_queue_messages_ready",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    }
  ]
}
